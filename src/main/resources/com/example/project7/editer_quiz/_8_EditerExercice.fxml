<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>
<?import com.jfoenix.controls.JFXButton?>

<VBox xmlns:fx="http://javafx.com/fxml/1"
      xmlns="http://javafx.com/javafx/17"
      fx:controller="com.example.project7.controller.edition.EditerExercice"
      spacing="15"
      style="-fx-background-color: white; -fx-padding: 20;">

    <HBox alignment="CENTER_LEFT" spacing="10">
        <Label text="📝 Create / Edit an Exercise

"
               style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #8B4789;"/>
    </HBox>

    <Separator/>

    <HBox spacing="10" alignment="CENTER_LEFT">
        <Label text="Exercise number :"
               prefWidth="150"
               style="-fx-font-weight: bold;"/>
        <Spinner fx:id="spinnerNumero"
                 prefWidth="80"
                 editable="true"/>
    </HBox>

    <VBox spacing="5">
        <Label text="Exercise title : *"
               style="-fx-font-weight: bold;"/>
        <TextField fx:id="txtTitre"
                   promptText="Ex: Algorithmes de tri"
                   style="-fx-border-color: #8B4789; -fx-border-radius: 5; -fx-padding: 8;"/>
    </VBox>

    <VBox spacing="5">
        <Label text="Instructions (optional) :"/>
        <TextArea fx:id="txtConsigne"
                  prefRowCount="4"
                  wrapText="true"
                  promptText="Instructions for the exercise..."
                  style="-fx-border-color: #8B4789; -fx-border-radius: 5;"/>
    </VBox>

    <HBox spacing="10" alignment="CENTER_LEFT">
        <Label text="Grading (points) :"
               prefWidth="150"
               style="-fx-font-weight: bold;"/>
        <TextField fx:id="txtBareme"
                   prefWidth="100"
                   promptText="Ex: 5.0"
                   text="0"
                   style="-fx-border-color: #8B4789; -fx-border-radius: 5; -fx-padding: 8;"/>
        <Label text="pts" style="-fx-font-weight: bold;"/>
    </HBox>

    <Separator/>

    <!-- ========== SECTION THÈMES ========== -->
    <VBox spacing="10" style="-fx-padding: 15; -fx-border-color: #CCCCCC; -fx-border-width: 1; -fx-border-radius: 5; -fx-background-color: #F9F9F9;">
        <Label text="📚 Exercise Topics " style="-fx-font-size: 13px; -fx-font-weight: bold;" />

        <HBox spacing="10" alignment="CENTER_LEFT">
            <children>
                <Label text="Add a topic :" prefWidth="110" style="-fx-font-size: 11px;" />

                <ComboBox fx:id="comboThemes" promptText="Select a topic..."
                          prefWidth="220" HBox.hgrow="ALWAYS" />

                <JFXButton fx:id="btnAjouterTheme" text="+ Add"
                           onAction="#handleAjouterTheme"
                           style="-fx-background-color: #4CAF50; -fx-text-fill: white;"
                           prefHeight="28.0" prefWidth="90.0" />

                <JFXButton fx:id="btnGererThemes" text="⚙️"
                           onAction="#handleOuvrirGestionThemes"
                           style="-fx-background-color: #FF9800; -fx-text-fill: white;"
                           prefHeight="28.0" prefWidth="35.0" />
            </children>
        </HBox>

        <!-- Liste des thèmes sélectionnés (chips) -->
        <FlowPane fx:id="flowPaneThemes" hgap="6" vgap="6" style="-fx-padding: 8; -fx-min-height: 40;">
            <!-- Les thèmes apparaîtront ici dynamiquement -->
        </FlowPane>

        <Label text="ℹ️ Topics help classify and easily find your exercises"
               style="-fx-font-size: 10px; -fx-text-fill: #666666; -fx-font-style: italic;"
               wrapText="true" />
    </VBox>

    <Separator/>

    <HBox spacing="15" alignment="CENTER_RIGHT" style="-fx-padding: 10 0 0 0;">
        <Button fx:id="btnAnnuler"
                text="Cancel"
                onAction="#handleAnnuler"
                prefWidth="120"
                prefHeight="35"
                style="-fx-background-color: #E0E0E0; -fx-text-fill: #333; -fx-font-size: 13px;"/>
        <Button fx:id="btnValider"
                text="✓ Save"
                onAction="#handleValider"
                prefWidth="120"
                prefHeight="35"
                style="-fx-background-color: #8B4789; -fx-text-fill: white; -fx-font-size: 13px; -fx-font-weight: bold;"/>
    </HBox>

    <padding>
        <Insets top="10" right="20" bottom="10" left="20"/>
    </padding>
</VBox>