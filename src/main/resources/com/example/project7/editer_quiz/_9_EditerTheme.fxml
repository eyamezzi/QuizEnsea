<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<AnchorPane xmlns="http://javafx.com/javafx/17.0.12"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.example.project7.controller.edition.EditerTheme"
            prefHeight="400.0" prefWidth="500.0"
            style="-fx-background-color: white; -fx-background-radius: 10;">

    <VBox spacing="15" AnchorPane.topAnchor="20" AnchorPane.leftAnchor="20"
          AnchorPane.rightAnchor="20" AnchorPane.bottomAnchor="20">

        <Label text="Gérer les Thèmes" style="-fx-font-size: 18px; -fx-font-weight: bold;" />

        <HBox spacing="10" alignment="CENTER_LEFT">
            <TextField fx:id="txtNomTheme" promptText="Nom du nouveau thème"
                       prefWidth="250" HBox.hgrow="ALWAYS" />
            <ColorPicker fx:id="colorPickerTheme" prefWidth="100" />
            <Button fx:id="btnAjouterTheme" text="+ Ajouter"
                    onAction="#handleAjouterTheme"
                    style="-fx-background-color: #4CAF50; -fx-text-fill: white;"
                    prefWidth="100" />
        </HBox>

        <TableView fx:id="tableThemes" prefHeight="250" VBox.vgrow="ALWAYS">
            <columns>
                <TableColumn fx:id="colNomTheme" text="Nom du Thème" prefWidth="200" />
                <TableColumn fx:id="colCouleurTheme" text="Couleur" prefWidth="100" />
                <TableColumn fx:id="colActionsTheme" text="Actions" prefWidth="150" />
            </columns>
        </TableView>

        <HBox spacing="10" alignment="CENTER">
            <Button text="Fermer" onAction="#handleFermer"
                    style="-fx-background-color: #cccccc;"
                    prefWidth="100" />
        </HBox>

    </VBox>
</AnchorPane>