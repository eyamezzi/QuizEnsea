<?xml version="1.0" encoding="UTF-8"?>

<?import com.jfoenix.controls.*?>
<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<AnchorPane prefHeight="600.0" prefWidth="794.0" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.project7.controller.edition.EditerProjet">
    <children>
        <ScrollPane fitToWidth="true" fitToHeight="true" prefHeight="600.0" prefWidth="794.0">
            <content>
                <VBox prefWidth="774.0">
                    <children>
                        <GridPane prefHeight="380.0" prefWidth="774.0">
                            <columnConstraints>
                                <ColumnConstraints hgrow="SOMETIMES" maxWidth="392.0" minWidth="10.0" prefWidth="379.0" />
                                <ColumnConstraints hgrow="SOMETIMES" maxWidth="441.0" minWidth="10.0" prefWidth="395.0" />
                            </columnConstraints>
                            <rowConstraints>
                                <RowConstraints minHeight="10.0" prefHeight="40.0" vgrow="SOMETIMES" />
                                <RowConstraints minHeight="10.0" prefHeight="40.0" vgrow="SOMETIMES" />
                                <RowConstraints minHeight="10.0" prefHeight="40.0" vgrow="SOMETIMES" />
                                <RowConstraints minHeight="10.0" prefHeight="100.0" vgrow="SOMETIMES" />
                                <RowConstraints minHeight="10.0" prefHeight="40.0" vgrow="SOMETIMES" />
                                <RowConstraints minHeight="10.0" prefHeight="40.0" vgrow="SOMETIMES" />
                            </rowConstraints>
                            <children>
                                <!-- Ligne 0 : Assignment Name -->
                                <Label prefHeight="27.0" prefWidth="191.0" text="Assignment Name :" GridPane.rowIndex="0">
                                    <GridPane.margin>
                                        <Insets left="175.0" />
                                    </GridPane.margin>
                                    <font>
                                        <Font size="20.0" />
                                    </font>
                                </Label>
                                <TextField fx:id="nomDevoir" prefHeight="39.0" prefWidth="346.0" promptText="By Default will be the name of the assignment" GridPane.columnIndex="1" GridPane.rowIndex="0">
                                    <GridPane.margin>
                                        <Insets left="10.0" right="40.0" />
                                    </GridPane.margin>
                                </TextField>

                                <!-- Ligne 1 : Type Devoir et Date -->
                                <MenuButton fx:id="typeDevoir" alignment="CENTER" mnemonicParsing="false" prefHeight="39.0" prefWidth="327.0" text="Please Select Type Devoir" GridPane.rowIndex="1">
                                    <GridPane.margin>
                                        <Insets left="30.0" right="10.0" />
                                    </GridPane.margin>
                                </MenuButton>
                                <DatePicker fx:id="dateDevoir" editable="false" prefHeight="39.0" prefWidth="364.0" promptText="Please select the Date Of Devoir" GridPane.columnIndex="1" GridPane.rowIndex="1">
                                    <GridPane.margin>
                                        <Insets left="10.0" right="30.0" />
                                    </GridPane.margin>
                                </DatePicker>

                                <!-- Ligne 2 : Default Theme -->
                                <Label text="Default Theme :" GridPane.rowIndex="2">
                                    <GridPane.margin>
                                        <Insets left="175.0" />
                                    </GridPane.margin>
                                    <font>
                                        <Font size="20.0" />
                                    </font>
                                </Label>
                                <ComboBox fx:id="comboThemeParDefaut"
                                          promptText="Select a default theme"
                                          prefHeight="39.0"
                                          prefWidth="346.0"
                                          GridPane.columnIndex="1"
                                          GridPane.rowIndex="2">
                                    <GridPane.margin>
                                        <Insets left="10.0" right="40.0" />
                                    </GridPane.margin>
                                </ComboBox>

                                <!-- Ligne 3 : Exam Header avec bouton -->
                                <HBox alignment="CENTER_LEFT" spacing="5" GridPane.rowIndex="3" GridPane.columnSpan="1">
                                    <GridPane.margin>
                                        <Insets left="30.0" right="10.0" top="5.0" bottom="5.0" />
                                    </GridPane.margin>
                                    <children>
                                        <TextArea fx:id="examHeader" prefHeight="80.0" wrapText="true" promptText="Exam Header" HBox.hgrow="ALWAYS" />
                                        <Button mnemonicParsing="false" onAction="#modifyExamHeader" text="..." prefWidth="40.0" prefHeight="30.0" />
                                    </children>
                                </HBox>

                                <!-- Ligne 3 : Response Header avec bouton -->
                                <HBox alignment="CENTER_LEFT" spacing="5" GridPane.columnIndex="1" GridPane.rowIndex="3">
                                    <GridPane.margin>
                                        <Insets left="10.0" right="30.0" top="5.0" bottom="5.0" />
                                    </GridPane.margin>
                                    <children>
                                        <TextArea fx:id="reponseHeader" prefHeight="80.0" wrapText="true" promptText="Response Header" HBox.hgrow="ALWAYS" />
                                        <Button mnemonicParsing="false" onAction="#modifyReponseHeader" text="..." prefWidth="40.0" prefHeight="30.0" />
                                    </children>
                                </HBox>
                                <!-- Ligne 4 : Number of Copies et Random Seed -->
                                <Label prefHeight="48.0" prefWidth="193.0" text="Number of Copies :" GridPane.rowIndex="4">
                                    <font>
                                        <Font size="20.0" />
                                    </font>
                                    <GridPane.margin>
                                        <Insets left="30.0" />
                                    </GridPane.margin>
                                </Label>
                                <TextField fx:id="nombreExemplaire" onKeyTyped="#handleInputNumber" prefHeight="39.0" prefWidth="155.0" promptText="Copie" GridPane.rowIndex="4">
                                    <GridPane.margin>
                                        <Insets left="230.0" right="20.0" />
                                    </GridPane.margin>
                                </TextField>
                                <Label alignment="CENTER" contentDisplay="CENTER" prefHeight="48.0" prefWidth="145.0" text="Random Seed :" textAlignment="CENTER" GridPane.columnIndex="1" GridPane.rowIndex="4">
                                    <font>
                                        <Font size="20.0" />
                                    </font>
                                    <GridPane.margin>
                                        <Insets left="10.0" />
                                    </GridPane.margin>
                                </Label>
                                <TextField fx:id="randomSeed" onKeyTyped="#handleInputNumber" prefHeight="42.0" prefWidth="162.0" promptText="Random Seed" GridPane.columnIndex="1" GridPane.rowIndex="4">
                                    <GridPane.margin>
                                        <Insets left="200.0" right="38.0" />
                                    </GridPane.margin>
                                </TextField>

                                <!-- Ligne 5 : Boutons Import et Add -->
                                <Button mnemonicParsing="false" onAction="#handleClicksImportSection" prefHeight="39.0" prefWidth="328.0" style="-fx-background-color: #873E59;" text="Import Question or Description" textFill="WHITE" GridPane.rowIndex="5">
                                    <GridPane.margin>
                                        <Insets left="30.0" />
                                    </GridPane.margin>
                                </Button>
                                <Button alignment="CENTER" contentDisplay="CENTER" mnemonicParsing="false" onAction="#handleClicksAddSection" prefHeight="39.0" prefWidth="365.0" style="-fx-background-color: C9B7BE;" text="Add Question or Description" textAlignment="CENTER" GridPane.columnIndex="1" GridPane.rowIndex="5">
                                    <GridPane.margin>
                                        <Insets left="10.0" right="30.0" />
                                    </GridPane.margin>
                                </Button>
                            </children>
                        </GridPane>

                        <!-- TableView -->
                        <TableView fx:id="tableSection" prefHeight="200.0" prefWidth="774.0">
                            <columns>
                                <TableColumn fx:id="numCol" prefWidth="95.33334350585938" text="Num°" />
                                <TableColumn fx:id="typeCol" prefWidth="165.0" text="Type" />
                                <TableColumn fx:id="exerciceNumCol" text="Num Ex" prefWidth="60" />
                                <TableColumn fx:id="enonceCol" prefWidth="299.0" text="Section Statement" />
                                <TableColumn fx:id="actionCol" prefWidth="139.0" text="Action" />
                            </columns>
                            <VBox.margin>
                                <Insets left="30.0" right="38.0" top="10.0" />
                            </VBox.margin>
                        </TableView>

                        <!-- Boutons Done et Cancel -->
                        <HBox alignment="CENTER" prefHeight="80.0" prefWidth="774.0" spacing="50.0">
                            <VBox.margin>
                                <Insets top="10.0" bottom="20.0" />
                            </VBox.margin>
                            <children>
                                <JFXButton fx:id="terminer" onAction="#handleClicksSaveProject" prefHeight="39.0" prefWidth="97.0" style="-fx-background-color: #A53860;" text="Done" textFill="WHITE" />


                                <JFXButton fx:id="cancel" onAction="#handleClicksCancelProject" prefHeight="39.0" prefWidth="91.0" style="-fx-background-color: fff0f3;" text="Cancel" />
                            </children>
                        </HBox>
                    </children>
                </VBox>
            </content>
        </ScrollPane>
    </children>
</AnchorPane>
